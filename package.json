{
  "name": "taskmanager-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --filter apps/web dev",
    "dev:mobile": "pnpm --filter apps/mobile dev",
    "build": "NODE_ENV=production pnpm --filter apps/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
